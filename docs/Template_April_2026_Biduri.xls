            .s { background-color: #fef3c7; color: #92400e; text-align: center; font-weight: bold; border: 1px solid #000000; }
            .i { background-color: #f3e8ff; color: #6b21a8; text-align: center; font-weight: bold; border: 1px solid #000000; }
